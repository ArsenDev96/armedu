# ---------------------------------------------------------------------------
# Armat — local environment
#
# Copy this file to `.env.local` and fill in the two values from your Supabase
# project (Project Settings → API). `.env.local` is git-ignored.
#
# Supabase is used for ONE purpose: storing newsletter email addresses. All
# educational content lives in local TypeScript files under src/data.
#
# Both variables are NEXT_PUBLIC_ on purpose — the anon key is meant to be
# public and is protected by row level security, not by secrecy.
#
# NEVER put the service_role key in this file or in any NEXT_PUBLIC_ variable.
# It bypasses row level security and would be shipped to every visitor.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Contact form — SMTP
#
# Used ONLY by the server route /api/contact. None of these carry the
# NEXT_PUBLIC_ prefix, so they never reach the browser bundle — that is the
# whole reason the contact form posts to a server route instead of talking to
# a mail service directly. Do not add the prefix to any of them.
#
# SMTP_SECURE=true for implicit TLS on port 465; leave it false for 587, which
# upgrades via STARTTLS. If your provider gave you a dedicated app password,
# use that as SMTP_PASSWORD rather than the account's own password.
#
# CONTACT_FROM_EMAIL must be an address the server is allowed to send as — it
# defaults to SMTP_USER. The reader's own address is set as Reply-To, never as
# the sender, because that would fail SPF and land the message in spam.
# CONTACT_TO_EMAIL is where messages arrive; it defaults to the site's
# published contact address.
# ---------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
